{
  "host": "127.0.0.1",
  "port": 8788,
  "jwt_secret": "change-me-local-authnode-secret",
  "issuer": "authnode.local",
  "default_audience": ["fastreact", "pska"],
  "token_ttl_seconds": 28800,
  "session_ttl_seconds": 28800,
  "strict_identity": false,
  "admin_token": "",
  "identity_mode": "hybrid",
  "browser_login_provider": "local_iam",
  "strict_membership": true,
  "catalog_store": {
    "type": "sqlite",
    "path": "./data/authnode.db"
  },
  "password_policy": {
    "min_length": 10
  },
  "login_rate_limit": {
    "max_attempts": 5,
    "window_seconds": 300
  },
  "dev_login_password": "pska-local",
  "allow_unknown_users": true,
  "allow_unknown_tenants": true,
  "keycloak": {
    "issuer_url": "http://127.0.0.1:8080/realms/pska-local",
    "client_id": "authnode",
    "client_secret_env": "AUTHNODE_KEYCLOAK_CLIENT_SECRET",
    "redirect_uri": "http://127.0.0.1:8788/oidc/callback",
    "scopes": ["openid", "profile", "email"],
    "tenant_claims": ["tenant_id", "tenant_key"],
    "user_id_claims": ["preferred_username", "sub"],
    "role_claims": ["roles", "realm_access.roles"],
    "group_claims": ["groups"]
  },
  "targets": {
    "fastreact": {
      "base_url": "http://127.0.0.1:18741",
      "mode": "jwt"
    },
    "pska": {
      "base_url": "http://127.0.0.1:8765",
      "mode": "jwt"
    }
  },
  "tenants": [
    {
      "tenant_id": "tenant_default",
      "tenant_key": "tenant_default",
      "name": "Default Local Tenant"
    },
    {
      "tenant_id": "tenant_acme",
      "tenant_key": "tenant_acme",
      "name": "Acme Local Tenant"
    }
  ],
  "users": [
    {
      "user_id": "user_primary",
      "user_key": "pska:user_primary",
      "tenant_id": "tenant_default",
      "tenant_key": "tenant_default",
      "display_name": "Primary Local User",
      "password": "primary-local",
      "email": "primary@example.test",
      "roles": ["admin"],
      "groups": ["local"]
    },
    {
      "user_id": "alice",
      "user_key": "pska:alice",
      "tenant_id": "tenant_acme",
      "tenant_key": "tenant_acme",
      "display_name": "Alice Acme",
      "password": "alice-local",
      "email": "alice@example.test",
      "roles": ["writer"],
      "groups": ["acme"]
    }
  ]
}
